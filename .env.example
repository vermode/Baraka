# Copy this file to `.env` (in the same folder) and fill in real values.
# Never commit your real `.env` — it contains secrets.

# ---- Database ---------------------------------------------------------------
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# The user, password, and database must already exist in MySQL.
# See docs/HOW_TO/setup-mysql.md for how to create them.
DATABASE_URL=mysql://baraka_app:CHANGE_ME@localhost:3306/baraka

# ---- Session signing key ----------------------------------------------------
# Used to sign the login cookie. Must be at least 32 characters.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_me_with_at_least_32_random_characters_pls

# ---- Optional ---------------------------------------------------------------
# Comma-separated list of origins the API will accept browser requests from.
# Default is the Vite dev server. Add more for staging / production.
# CORS_ORIGIN=http://localhost:5173
# Server port (default 8080).
# PORT=8080

# Log verbosity: trace | debug | info | warn | error | fatal
# LOG_LEVEL=info

# Error-tracking service DSN (e.g. Sentry). Leave unset to disable; when set,
# wire the SDK in backend/src/lib/observability.ts.
# ERROR_TRACKING_DSN=

# Set to "production" only on a real deployed server.
# NODE_ENV=development
