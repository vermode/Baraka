{
  "name": "@workspace/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm run build && node --enable-source-maps --env-file-if-exists=../.env ./dist/index.mjs",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:push": "node --env-file-if-exists=../.env node_modules/drizzle-kit/bin.cjs push --config ./src/db/drizzle.config.ts",
    "db:push-force": "node --env-file-if-exists=../.env node_modules/drizzle-kit/bin.cjs push --force --config ./src/db/drizzle.config.ts",
    "db:migrate-from-postgres": "node --env-file-if-exists=../.env --import tsx ./src/db/migrate-from-postgres.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@workspace/api-zod": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "drizzle-orm": "catalog:",
    "drizzle-zod": "^0.8.3",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "mysql2": "^3.11.4",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pg": "^8.20.0",
    "pino-pretty": "^13.1.3",
    "thread-stream": "3.1.0",
    "tsx": "catalog:"
  }
}
